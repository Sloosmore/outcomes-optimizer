{
  "name": "cli-adaptive",
  "version": "0.1.0",
  "type": "module",
  "description": "Wrap any CLI framework to capture unknown commands, learn from agent behavior, and promote persistent aliases",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@oclif/core": ">=3",
    "commander": ">=12",
    "yargs": ">=17"
  },
  "peerDependenciesMeta": {
    "commander": {
      "optional": true
    },
    "yargs": {
      "optional": true
    },
    "@oclif/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@oclif/core": "^4.10.5",
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.35",
    "commander": "^13.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "yargs": "^18.0.0"
  }
}
