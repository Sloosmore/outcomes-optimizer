# Pre-compiled dispatch bundles — generated by `node utils/dispatch/build-bundles.mjs`
# at build time (.docker/build-packages.sh runs it after workspace packages are built).
# Self-contained ESM bundles of dispatch.ts/provision.ts/launch.ts/loop/index.ts that
# eliminate tsx cold-start overhead on the dispatch hot path. Source-of-truth is the
# .ts files; the bundles are derived artifacts, like dist/.
*.prebuilt.mjs

# Turborepo local cache + per-user config
.turbo/

# Local Claude Code state (settings, skills, worktrees) — not for OSS distribution
.claude/

