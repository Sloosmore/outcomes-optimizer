# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Used by test-realtime-creds.mjs — enable the anonymous provider in the Supabase Auth dashboard before running the realtime credential gate.
SUPABASE_ANON_KEY=

# ── AI providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# API key sent to ANTHROPIC_BASE_URL for orchestrator inference (voice-agent.ts / local-llm-stream.ts).
# Falls back to OPENAI_API_KEY, then the 'local-dev-key' sentinel for a local proxy that skips validation.
LLM_API_KEY=
# Override the orchestrator's voice-agent LLM model (defaults to claude-haiku-4-5).
LLM_MODEL=

# ── Sandbox subagent (research.mjs) ───────────────────────────────────────────
# The in-sandbox claude-agent-sdk runner. This is intentionally separate from
# the orchestrator's ANTHROPIC_BASE_URL — splitting the env vars keeps the two
# paths independently configurable.
SANDBOX_ANTHROPIC_BASE_URL=
SANDBOX_ANTHROPIC_API_KEY=
SANDBOX_RESEARCH_MODEL=

# ── Credential proxy (optional) ───────────────────────────────────────────────
# If set, AI API calls are routed through the local credential proxy.
CREDENTIAL_PROXY_URL=

# ── Vite client-side (baked in at build time) ─────────────────────────────────
# ArtifactPanel iframe src is built via @skill-networks/artifact-url's
# buildArtifactUrl() — single-label artifact-<sandboxId>-<port>.<artifact-domain>.
# No tunnel-domain env var is required; the *.<artifact-domain> wildcard CNAME
# routes every artifact through the artifact-router service.
# Set to "1" to expose window.__sendText and window.__injectArtifact for e2e tests.
VITE_TEST=
# Supabase public vars for frontend Realtime subscriptions (anon key only — never expose service key).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Dev auto-login: when set, the app signs in automatically with these credentials on load.
# Never set in production builds — a build-time guard throws if set with PROD=true.
VITE_DEBUG_EMAIL=
VITE_DEBUG_PASSWORD=
