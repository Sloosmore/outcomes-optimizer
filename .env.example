# outcomes-optimizer — example env config
# Copy to `.env` and fill in. None of the values below are required to merely
# build the repo; they are required to run the corresponding feature.

# --- Database (Supabase / Postgres) ---
# Pooled URL (Supavisor) for app code; direct URL for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
SUPABASE_URL=https://<your-supabase-project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Anthropic / Claude ---
# Override base URL if routing through a local credential proxy or gateway.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=

# --- Artifact router ---
# Base domain for artifact subdomains (`artifact-<sandboxId>-<port>.<domain>`).
# Defaults to `example.com` if unset.
ARTIFACT_BASE_DOMAIN=example.com

# --- Sandbox provider (Hetzner Cloud) ---
HETZNER_API_TOKEN=

# --- Cloudflare (artifact DNS / tunnels, optional) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# --- Credential proxy + secrets manager (optional) ---
# The credential proxy ships with a Doppler-backed store; you can swap it for
# any CredentialStore implementation. If using Doppler:
DOPPLER_SERVICE_TOKEN=
DOPPLER_PROJECT=
DOPPLER_CONFIG=

# --- LiveKit (optional, for the agent-livestream voice chat) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- GitHub App (optional, for repo-clone / PR review flows) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_INSTALL_ID=

# --- Turborepo remote cache (optional) ---
TURBO_TOKEN=
TURBO_TEAM=
